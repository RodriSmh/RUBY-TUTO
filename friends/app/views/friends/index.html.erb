<p style="color: green"><%= notice %></p>

<% content_for :title, "Friends" %>

<h1>Friends</h1>

<div id="friends">
<table class="table">
  <thead class="thead-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>phone</th>
        <th>twitter </th>
        <th colspan="3"></th>
      </tr>
  </thead>
  <tbody>
    <% @friends.each do |friend| %>
      <tr id="<%= dom_id(friend) %>">
        <td><%= friend.first_name %></td>
        <td><%= friend.email %></td>
        <td><%= friend.phone %></td>
        <td><%= friend.twitter %></td>
        <td><%= link_to "Show", friend, class: "btn btn-sm btn-primary" %></td>
        <td><%= link_to "Edit", edit_friend_path(friend), class: "btn btn-sm btn-secondary" %></td>
        <td><%= button_to "Destroy", friend, method: :delete, class: "btn btn-sm btn-danger" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

</div>

<%= link_to "New friend", new_friend_path, class: "btn btn-light"%>
